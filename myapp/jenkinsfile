pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                git 'https://github.com/Kunal455/end-term-practical.git'
            }
        }

        stage('Build') {
            steps {
                bat 'mvn clean package'
            }
        }

        stage('Test') {
            steps {
                bat 'mvn test'
            }
        }

        stage('Docker Build') {
            steps {
                bat 'docker build -t kunalkumar123/javaapp:latest .'
            }
        }

        stage('Docker Push') {
            steps {
                bat 'docker push kunalkumar123/javaapp:latest'
            }
        }
    }
}